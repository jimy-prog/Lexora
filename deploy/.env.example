# Copy to deploy/.env and fill before: docker compose -f deploy/docker-compose.yml up -d --build
#
# Required
SESSION_SECRET_KEY=use-openssl-rand-hex-32-or-similar
DEFAULT_ADMIN_PASSWORD=your-strong-password
POSTGRES_PASSWORD=your-strong-db-password

# Optional
APP_NAME=Lexora
POSTGRES_USER=lexora
POSTGRES_DB=lexora
EXPOSE_PORT=8000

# Cloudflare Tunnel (only if you use: docker compose ... --profile tunnel)
# CLOUDFLARE_TUNNEL_TOKEN=eyJhI...
